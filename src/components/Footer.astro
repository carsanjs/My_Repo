            </g>
          </svg>
        </span>

        <span>Astro</span>
      </div>
    </section>

    <section class="footer-bottom">
      <p>
        Copyright © {currentYear}
        <span class="separator">|</span>
        Casi todos los derechos reservados
      </p>

      <div class="last-updated">
        <LastUpdated client:only="react" />
      </div>
    </section>
  </div>
</footer>

<style>
  .portfolio-footer {
    width: 100%;
    padding: 40px 20px 32px;
    background:
      radial-gradient(circle at bottom right, rgba(10, 233, 138, 0.14), transparent 32%),
      linear-gradient(135deg, #f8fafc 0%, #eef2f7 100%);
  }

  .footer-container {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
  }

  .footer-card {
    display: grid;
    grid-template-columns: 1.1fr auto auto;
    gap: 28px;
    align-items: center;
    padding: 26px;
    border-radius: 26px;
    background-color: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(17, 24, 39, 0.08);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.1);
    backdrop-filter: blur(16px);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-badge {
    width: fit-content;
    padding: 7px 13px;
    border-radius: 999px;
    background-color: #0ae98a;
    color: #141515;
    font-size: 13px;
    font-weight: 800;
  }

  .footer-title {
    margin: 0;
    color: #111827;
    font-size: 22px;
    font-weight: 900;
    letter-spacing: -0.5px;
  }

  .footer-description {
    max-width: 520px;
    margin: 0;
    color: #6b7280;
    font-size: 15px;
    line-height: 1.6;
  }

  .footer-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .footer-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 9px 14px;
    border-radius: 999px;
    color: #374151;
    background-color: #f9fafb;
    border: 1px solid rgba(17, 24, 39, 0.08);
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    transition:
      color 200ms ease,
      background 200ms ease,
      border-color 200ms ease,
      transform 200ms ease,
      box-shadow 200ms ease;
  }

  .footer-nav a:hover {
    color: #141515;
    background-color: #0ae98a;
    border-color: transparent;
    box-shadow: 0 12px 24px rgba(10, 233, 138, 0.22);
    transform: translateY(-2px);
  }

  .footer-made {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    padding: 10px 14px;
    border-radius: 999px;
    color: #374151;
    background-color: #ffffff;
    border: 1px solid rgba(17, 24, 39, 0.08);
    font-size: 14px;
    font-weight: 700;
    white-space: nowrap;
  }

  .astro-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 6px 0;
    color: #6b7280;
    font-size: 14px;
  }

  .footer-bottom p {
    margin: 0;
  }

  .separator {
    margin: 0 8px;
    color: #9ca3af;
  }

  .last-updated {
    opacity: 0.85;
  }

  :global(.dark) .portfolio-footer {
    background:
      radial-gradient(circle at bottom right, rgba(10, 233, 138, 0.12), transparent 32%),
      linear-gradient(135deg, #0f172a 0%, #111827 100%);
  }

  :global(.dark) .footer-card {
    background-color: rgba(31, 41, 55, 0.82);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
  }

  :global(.dark) .footer-title {
    color: #f9fafb;
  }

  :global(.dark) .footer-description,
  :global(.dark) .footer-bottom {
    color: rgba(229, 231, 235, 0.75);
  }

  :global(.dark) .footer-nav a,
  :global(.dark) .footer-made {
    color: rgba(255, 255, 255, 0.82);
    background-color: rgba(17, 24, 39, 0.75);
    border-color: rgba(255, 255, 255, 0.08);
  }

  :global(.dark) .footer-nav a:hover {
    color: #141515;
    background-color: #0ae98a;
  }

  @media (max-width: 900px) {
    .footer-card {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }

    .footer-brand {
      align-items: center;
    }

    .footer-description {
      max-width: 620px;
    }

    .footer-bottom {
      flex-direction: column;
      justify-content: center;
      text-align: center;
    }
  }

  @media (max-width: 640px) {
    .portfolio-footer {
      padding: 32px 16px 24px;
    }

    .footer-card {
      padding: 22px;
      border-radius: 22px;
    }

    .footer-nav {
      width: 100%;
      flex-direction: column;
    }

    .footer-nav a {
      width: 100%;
    }

    .footer-made {
      width: 100%;
    }

    .separator {
      display: none;
    }
  }
</style>