---
interface Props {
  email?: string;
  linkedin?: string;
}

const {
  email = "carlosstqm2225@gmail.com",
  linkedin = "https://www.linkedin.com/in/casc25/",
} = Astro.props;
---

<section id="contacto" class="contact-section">
  <div class="contact-container">
    <div class="contact-content">
      <span class="section-badge">Contacto</span>

      <h2>
        ¿Tienes una idea o necesitas una web?
      </h2>

      <p>
        Escríbeme y conversemos sobre tu proyecto. Puedo ayudarte con páginas web,
        landing pages, portafolios, sistemas administrativos o mejoras visuales
        para tu sitio actual.
      </p>

      <div class="contact-actions">
        <a href={`mailto:${email}`} class="primary-link">
          Enviar correo
        </a>

        <a
          href={linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="secondary-link"
        >
          Hablar por LinkedIn
        </a>
      </div>
    </div>

    <div class="contact-box">
      <h3>Servicios que puedes solicitar</h3>

      <ul>
        <li>Página web para negocio o marca personal</li>
        <li>Landing page para vender servicios</li>
        <li>Portafolio profesional</li>
        <li>Dashboard o sistema web interno</li>
        <li>Rediseño y mejora de una web existente</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .contact-section {
    width: 100%;
    padding: 84px 20px;
    background:
      radial-gradient(circle at top right, rgba(30, 144, 255, 0.15), transparent 32%),
      linear-gradient(135deg, #0f172a 0%, #111827 60%, #020617 100%);
  }

  .contact-container {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 34px;
    align-items: center;
  }

  .section-badge {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 14px;
    padding: 8px 14px;
    border-radius: 999px;
    background-color: #0ae98a;
    color: #141515;
    font-size: 14px;
    font-weight: 900;
  }

  .contact-content h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -1.5px;
  }

  .contact-content p {
    max-width: 660px;
    margin: 20px 0 0;
    color: rgba(255, 255, 255, 0.76);
    font-size: 18px;
    line-height: 1.75;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .primary-link,
  .secondary-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 12px 18px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 900;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease,
      background 200ms ease,
      color 200ms ease,
      border-color 200ms ease;
  }

  .primary-link {
    color: #141515;
    background-color: #0ae98a;
    box-shadow: 0 14px 30px rgba(10, 233, 138, 0.22);
  }

  .primary-link:hover {
    background: linear-gradient(
      211deg,
      rgba(30, 144, 255, 1) 36%,
      rgba(10, 233, 138, 1) 52%
    );
    transform: translateY(-2px);
  }

  .secondary-link {
    color: rgba(255, 255, 255, 0.88);
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .secondary-link:hover {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.13);
    border-color: rgba(255, 255, 255, 0.22);
    transform: translateY(-2px);
  }

  .contact-box {
    padding: 30px;
    border-radius: 28px;
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(16px);
  }

  .contact-box h3 {
    margin: 0 0 18px;
    color: #ffffff;
    font-size: 24px;
  }

  .contact-box ul {
    display: grid;
    gap: 13px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact-box li {
    padding: 14px 16px;
    border-radius: 16px;
    color: rgba(255, 255, 255, 0.82);
    background-color: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-weight: 700;
  }

  @media (max-width: 850px) {
    .contact-container {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .contact-section {
      padding: 62px 16px;
    }

    .contact-actions {
      flex-direction: column;
    }

    .primary-link,
    .secondary-link {
      width: 100%;
    }

    .contact-box {
      padding: 22px;
      border-radius: 22px;
    }
  }
</style>