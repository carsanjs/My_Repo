---
const works = [
  {
    title: "Portafolio personal",
    category: "Página web",
    description:
      "Sitio web personal para mostrar servicios, experiencia, proyectos y medios de contacto.",
    technologies: ["Astro", "Tailwind", "Responsive"],
    status: "Realizado",
    url: "#",
  },
  {
    title: "Dashboard administrativo",
    category: "Sistema web",
    description:
      "Panel para gestionar información, visualizar datos importantes y controlar procesos internos.",
    technologies: ["Next.js", "React", "TypeScript"],
    status: "Realizado",
    url: "#",
  },
  {
    title: "Landing page de servicios",
    category: "Landing page",
    description:
      "Página enfocada en captar clientes, explicar servicios y facilitar el contacto directo.",
    technologies: ["Astro", "SEO", "Formulario"],
    status: "Realizado",
    url: "#",
  },
];
---

<section id="trabajos" class="works-section">
  <div class="works-container">
    <div class="section-header">
      <span class="section-badge">Mis trabajos</span>

      <h2>
        Proyectos realizados y soluciones web
      </h2>

      <p>
        Estos son algunos tipos de trabajos que puedo desarrollar para empresas,
        negocios, emprendimientos o marcas personales.
      </p>
    </div>

    <div class="works-grid">
      {
        works.map((work) => (
          <article class="work-card">
            <div class="work-top">
              <span>{work.category}</span>
              <small>{work.status}</small>
            </div>

            <h3>{work.title}</h3>

            <p>{work.description}</p>

            <div class="tech-list">
              {work.technologies.map((tech) => (
                <span>{tech}</span>
              ))}
            </div>

            <a href={work.url}>
              Ver detalle
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .works-section {
    width: 100%;
    padding: 84px 20px;
    background:
      radial-gradient(circle at top right, rgba(10, 233, 138, 0.14), transparent 30%),
      linear-gradient(135deg, #f8fafc 0%, #eef2f7 100%);
  }

  .works-container {
    max-width: 1180px;
    margin: 0 auto;
  }

  .section-header {
    max-width: 760px;
    margin-bottom: 38px;
  }

  .section-badge {
    display: inline-flex;
    width: fit-content;
    margin-bottom: 14px;
    padding: 8px 14px;
    border-radius: 999px;
    background-color: #0ae98a;
    color: #141515;
    font-size: 14px;
    font-weight: 900;
  }

  .section-header h2 {
    margin: 0;
    color: #111827;
    font-size: clamp(34px, 5vw, 54px);
    line-height: 1.05;
    letter-spacing: -1.4px;
  }

  .section-header p {
    margin: 18px 0 0;
    color: #6b7280;
    font-size: 18px;
    line-height: 1.7;
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    min-height: 330px;
    padding: 26px;
    border-radius: 26px;
    background-color: #ffffff;
    border: 1px solid rgba(17, 24, 39, 0.08);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    transition:
      transform 220ms ease,
      box-shadow 220ms ease,
      border-color 220ms ease;
  }

  .work-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 80px rgba(15, 23, 42, 0.13);
    border-color: rgba(10, 233, 138, 0.5);
  }

  .work-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 20px;
  }

  .work-top span,
  .work-top small {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    padding: 6px 11px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 900;
  }

  .work-top span {
    color: #141515;
    background-color: rgba(10, 233, 138, 0.18);
  }

  .work-top small {
    color: #2563eb;
    background-color: rgba(37, 99, 235, 0.1);
  }

  .work-card h3 {
    margin: 0;
    color: #111827;
    font-size: 24px;
    letter-spacing: -0.5px;
  }

  .work-card p {
    margin: 14px 0 0;
    color: #6b7280;
    font-size: 15px;
    line-height: 1.65;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 22px;
  }

  .tech-list span {
    padding: 7px 10px;
    border-radius: 999px;
    color: #374151;
    background-color: #f3f4f6;
    font-size: 12px;
    font-weight: 800;
  }

  .work-card a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 42px;
    margin-top: auto;
    padding: 10px 15px;
    border-radius: 999px;
    color: #141515;
    background-color: #0ae98a;
    text-decoration: none;
    font-size: 14px;
    font-weight: 900;
    transition: background 200ms ease, transform 200ms ease;
  }

  .work-card a:hover {
    background: linear-gradient(
      211deg,
      rgba(30, 144, 255, 1) 36%,
      rgba(10, 233, 138, 1) 52%
    );
    transform: translateY(-2px);
  }

  @media (max-width: 960px) {
    .works-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .works-section {
      padding: 62px 16px;
    }

    .works-grid {
      grid-template-columns: 1fr;
    }

    .work-card {
      min-height: auto;
      padding: 22px;
      border-radius: 22px;
    }
  }
</style>