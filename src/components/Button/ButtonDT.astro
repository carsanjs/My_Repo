---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="flex items-center">
  <button class="btn-custom dark:bg-gray-800 dark:text-white/80">
    <span class="text font-semibold text-sm">{title}</span>
  </button>
</div>

<style>
  .btn-custom {
    color: #141515;
    background-color: #0ae98a;

    display: inline-flex;
    justify-content: center;
    align-items: center;

    padding: 10px 15px;
    min-height: 40px;

    border: none;
    border-radius: 8px;
    box-sizing: border-box;

    cursor: pointer;
    line-height: 1;
    transition:
      background 300ms ease,
      color 300ms ease;
  }

  .btn-custom:hover {
    background: linear-gradient(
      211deg,
      rgba(30, 144, 255, 1) 36%,
      rgba(10, 233, 138, 1) 52%
    );
  }
</style>
