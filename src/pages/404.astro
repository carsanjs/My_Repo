---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Página no encontrada | Carlos Sánchez">
  <main class="not-found-page">
    <section class="not-found-card">
      <div class="error-visual" aria-hidden="true">
        <h1>404</h1>
      </div>

      <span class="badge">Página no encontrada</span>

      <h2>Ups, esta ruta no existe</h2>

      <p>
        Parece que el enlace está roto, fue movido o escribiste una dirección
        incorrecta. Puedes volver al inicio y seguir explorando mi portafolio.
      </p>

      <div class="actions">
        <a href="/" class="primary-button"> Volver al inicio </a>

        <a href="/trabajos" class="secondary-button"> Ver trabajos </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .not-found-page {
    width: 100%;
    min-height: 100vh;
    display: grid;
    place-items: center;
    background:
      radial-gradient(
        circle at top left,
        rgba(10, 233, 138, 0.22),
        transparent 34%
      ),
      radial-gradient(
        circle at bottom right,
        rgba(30, 144, 255, 0.18),
        transparent 32%
      ),
      linear-gradient(135deg, #0f172a 0%, #111827 55%, #020617 100%);
    overflow: hidden;
  }

  .not-found-card {
    position: relative;
    width: 100%;
    padding: 46px 34px;
    text-align: center;
    background-color: rgba(255, 255, 255, 0.08);
  }

  .error-visual {
    position: relative;
    display: grid;
    place-items: center;
    margin-bottom: 18px;
  }

  h1 {
    position: relative;
    margin: 0;
    color: #ffffff;
    font-size: clamp(96px, 22vw, 210px);
    line-height: 0.9;
    font-weight: 950;
    letter-spacing: -8px;
    text-shadow:
      0 0 24px rgba(10, 233, 138, 0.28),
      0 18px 60px rgba(0, 0, 0, 0.35);
  }

  .badge {
    display: inline-flex;
    width: fit-content;
    margin-top: 20px;
    padding: 8px 14px;
    border-radius: 999px;
    color: #141515;
    background-color: #0ae98a;
    font-size: 14px;
    font-weight: 900;
  }

  h2 {
    margin: 0;
    color: #ffffff;
    font-size: clamp(30px, 5vw, 48px);
    line-height: 1.05;
    letter-spacing: -1.2px;
    font-weight: 950;
  }

  p {
    max-width: 600px;
    margin: 18px auto 0;
    color: rgba(255, 255, 255, 0.76);
    font-size: 18px;
    line-height: 1.7;
  }

  .actions {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }

  .primary-button,
  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 12px 18px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 15px;
    font-weight: 900;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease,
      background 200ms ease,
      color 200ms ease,
      border-color 200ms ease;
  }

  .primary-button {
    color: #141515;
    background-color: #0ae98a;
    box-shadow: 0 14px 30px rgba(10, 233, 138, 0.24);
  }

  .primary-button:hover {
    background: linear-gradient(
      211deg,
      rgba(30, 144, 255, 1) 36%,
      rgba(10, 233, 138, 1) 52%
    );
    transform: translateY(-2px);
  }

  .secondary-button {
    color: rgba(255, 255, 255, 0.88);
    background-color: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }

  .secondary-button:hover {
    color: #ffffff;
    background-color: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.24);
    transform: translateY(-2px);
  }

  @keyframes pulseGlow {
    0%,
    100% {
      opacity: 0.65;
      transform: scale(1);
    }

    50% {
      opacity: 1;
      transform: scale(1.1);
    }
  }

  @media (max-width: 640px) {
    .not-found-page {
      padding: 82px 16px 42px;
    }

    .not-found-card {
      padding: 34px 20px;
    }

    h1 {
      letter-spacing: -4px;
    }

    p {
      font-size: 16px;
    }

    .actions {
      flex-direction: column;
    }

    .primary-button,
    .secondary-button {
      width: 100%;
    }
  }

  :global(.dark) .not-found-page {
    background:
      radial-gradient(
        circle at top left,
        rgba(10, 233, 138, 0.22),
        transparent 34%
      ),
      radial-gradient(
        circle at bottom right,
        rgba(30, 144, 255, 0.18),
        transparent 32%
      ),
      linear-gradient(135deg, #0f172a 0%, #111827 55%, #020617 100%);
  }
</style>
